      "weight": 1,
      "steps": [
        {
          "type": "click",
          "selector": "[data-replica='login-button']"
        }
      ],
      "assertions": [
        {
          "type": "expectVisible",
          "selector": "[data-replica='form-error']"
        },
        {
          "type": "expectTextIncludes",
          "selector": "[data-replica='form-error']",
          "value": "请输入"
        }
      ]
    },
    {
      "id": "typed-submit-failure",
      "name": "Fill fields and click login to show local failure feedback",
      "weight": 1,
      "steps": [
        {
          "type": "fill",
          "selector": "[data-replica='username-input']",
          "value": "merchant@example.com"
        },
        {
          "type": "fill",
          "selector": "[data-replica='password-input']",
          "value": "password123"
        },
        {
          "type": "fill",
          "selector": "[data-replica='captcha-input']",
          "value": "9K2P"
        },
        {
          "type": "click",
          "selector": "[data-replica='login-button']"
        },
        {
          "type": "wait",
          "ms": 700
        }
      ],
      "assertions": [
        {
          "type": "expectVisible",
          "selector": "[data-replica='form-error']"
        },
        {
          "type": "expectTextIncludes",
          "selector": "[data-replica='form-error']",
          "value": "验证码"
        }
      ]
    }
